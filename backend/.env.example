# Copy to .env and fill in. See docs/06-architecture-infrastructure.md §7 for
# local dev setup (supabase start prints the local DATABASE_URL).

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public"

PORT=3000
FRONTEND_ORIGIN="http://localhost:5173"

# From `supabase status` (API_URL) — used to fetch Supabase's JWKS for admin
# token verification.
SUPABASE_URL="http://127.0.0.1:54321"
# The one owner account's Supabase Auth user id — see backend/README.md
# "Admin auth" for how to create it locally.
ADMIN_USER_ID=""
